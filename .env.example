# Robot Battery Monitor — environment variables
# Copy to .env:  cp .env.example .env

# --- PostgreSQL ---
POSTGRES_USER=robot
POSTGRES_PASSWORD=robot
POSTGRES_DB=robot_battery
POSTGRES_PORT=5432

# --- Dashboard ---
DASHBOARD_PORT=5000
DATABASE_URL=postgresql://robot:robot@postgres:5432/robot_battery

# --- Hardware mode ---
# simulator | real
HARDWARE_MODE=real
# generic | ros2
HARDWARE_TYPE=ros2
# true = built-in mock pub/sub (no rclpy required in dashboard container)
ROS2_MOCK=true

# --- ROS2 (shared DDS domain for dashboard + ros2-sim) ---
ROS_DOMAIN_ID=0
ROS2_START_DELAY=10
ROS2_SIM_INTERVAL=5

# --- Logging ---
LOG_LEVEL=INFO

# --- Database wait (container startup) ---
DB_WAIT_ATTEMPTS=30
DB_WAIT_INTERVAL=2