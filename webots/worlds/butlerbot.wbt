        children [
          Shape {
            appearance PBRAppearance {
              baseColor 0.25 0.42 0.55
            }
            geometry Box {
              size 0.22 0.18 0.12
            }
          }
          DEF LEFT_ARM_JOINT HingeJoint {
            jointParameters HingeJointParameters {
              axis 0 1 0
              anchor 0 0.12 0.04
              dampingConstant 1.5
            }
            device [
              RotationalMotor {
                name "left_arm"
                maxVelocity 1.5
                maxTorque 1.2
              }
