            radius 0.035
          }
        }
      ]
      boundingObject Sphere {
        radius 0.035
      }
      physics Physics {
        density -1
        mass 0.08
        centerOfMass [
          0 0 0
        ]
        inertiaMatrix [
          3.92e-05 3.92e-05 3.92e-05
          0 0 0
        ]
      }
    }
    DEF TORSO_JOINT HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 0 1
        anchor 0 0 0.17
        dampingConstant 2.0
      }
      device [
        RotationalMotor {
          name "torso_joint"
          maxVelocity 1.2
          maxTorque 1.8
        }
        PositionSensor {
          name "torso_sensor"
        }
      ]
      endPoint Solid {
        name "torso_solid"
