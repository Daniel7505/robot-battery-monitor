                centerOfMass [
                  0 0 0
                ]
                inertiaMatrix [
                  6.5e-04 6.5e-04 9.0e-05
                  0 0 0
                ]
              }
            }
          }
          DEF RIGHT_ARM_JOINT HingeJoint {
            jointParameters HingeJointParameters {
              axis 0 1 0
              anchor 0 -0.12 0.04
              dampingConstant 1.5
            }
            device [
              RotationalMotor {
                name "right_arm"
                maxVelocity 1.5
                maxTorque 1.2
              }
              PositionSensor {
                name "right_arm_sensor"
              }
            ]
            endPoint Solid {
              name "right_arm_solid"
              translation 0 -0.12 0.04
              children [
                Shape {
                  appearance PBRAppearance {
                    baseColor 0.55 0.45 0.35
                  }
                  geometry Box {
                    size 0.06 0.06 0.22
                  }
                }
              ]
              boundingObject Box {
                size 0.06 0.06 0.22
              }
              physics Physics {
                density -1
                mass 0.15
                centerOfMass [
                  0 0 0
                ]
                inertiaMatrix [
