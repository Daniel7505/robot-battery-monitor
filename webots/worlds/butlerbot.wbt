                  appearance PBRAppearance {
                    baseColor 0.55 0.45 0.35
                  }
                  geometry Box {
                    size 0.06 0.06 0.22
                  }
                }
              ]
              boundingObject Box {
                size 0.06 0.06 0.22
              }
              physics Physics {
                density -1
