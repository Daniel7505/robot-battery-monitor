#VRML_SIM R2025a utf8

EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackground.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/backgrounds/protos/TexturedBackgroundLight.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/appearances/protos/Parquetry.proto"
EXTERNPROTO "https://raw.githubusercontent.com/cyberbotics/webots/R2025a/projects/objects/floors/protos/Floor.proto"

WorldInfo {
  basicTimeStep 32
  coordinateSystem "ENU"
  contactProperties [
    ContactProperties {
      coulombFriction [
        4
      ]
      bounce 0
      softCFM 0.0001
    }
  ]
  info [
    "ButlerBot Neo — upright wheeled humanoid (abstract Unitree Neo proportions)"
    "Vertical wheels on hips; torso + head + arms on compact pelvis"
  ]
}

Viewpoint {
  follow "ButlerBot"
  followType "Tracking Shot"
  orientation -0.22 0.28 0.93 0.95
  position 0 -2.4 1.35
  fieldOfView 0.9
}

TexturedBackground {
  texture "noon_cloudy_countryside"
  luminosity 1.2
}

TexturedBackgroundLight {
  texture "noon_cloudy_countryside"
  castShadows TRUE
}

Floor {
  name "ground"
  size 16 16
  tileSize 0.5 0.5
  appearance Parquetry {
    type "chequered"
    colorOverride 0.55 0.56 0.58
  }
}

Robot {
  translation 0 0 0
  rotation 0 0 1 0
  name "ButlerBot"
  controller "butlerbot_controller"
  controllerArgs [
    "--dashboard-url=http://127.0.0.1:5000"
  ]
  customData "ButlerBot Neo — upright wheeled humanoid ~0.95m"
  children [
    DEF PELVIS_VIS Transform {
      translation 0 0 0.20
      children [
        Shape {
          appearance PBRAppearance {
            baseColor 0.14 0.15 0.18
            roughness 0.45
            metalness 0.25
          }
          geometry Box {
            size 0.18 0.11 0.07
          }
        }
      ]
    }
    DEF LEFT_WHEEL_JOINT HingeJoint {
      jointParameters HingeJointParameters {
        axis 0 1 0
        anchor 0 0.17 0.08
        dampingConstant 0.1
      }
      device [
        RotationalMotor {
          name "left_wheel"
          maxVelocity 15
          maxTorque 50
        }
        PositionSensor {
          name "left_wheel_sensor"
        }
      ]
      endPoint Solid {
        name "left_wheel_solid"
        translation 0 0.17 0.08
        children [
          Pose {
            rotation 1 0 0 1.5708
            children [
              Shape {
                appearance PBRAppearance {
                  baseColor 0.08 0.08 0.1
                }
                geometry Cylinder {
                  height 0.03
                  radius 0.08
                }
              }
            ]
          }
        ]
        boundingObject Pose {
          rotation 1 0 0 1.5708
          children [
            Cylinder {
              height 0.03
              radius 0.08
            }
          ]
        }
        physics Physics {
          density -1
          mass 0.6
          centerOfMass [
            0 0 0
          ]
          inertiaMatrix [
            6.4e-04 1.15e-03 6.4e-04
            0 0 0
          ]
        }
      }
    }
    DEF RIGHT_WHEEL_JOINT HingeJoint {
